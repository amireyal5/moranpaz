
{
  "entities": {
    "BlogPost": {
      "title": "Blog Post",
      "description": "A dynamic article for the BeinMe blog.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The main headline of the post." },
        "subtitle": { "type": "string", "description": "A secondary sub-headline." },
        "summary": { "type": "string", "description": "A short excerpt shown in the blog list." },
        "slug": { "type": "string", "description": "URL-friendly version of the title." },
        "content": { "type": "string", "description": "The main body content of the article (HTML)." },
        "heroImageUrlDesktop": { "type": "string" },
        "heroImageUrlMobile": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "category": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "slug", "content", "date", "category"]
    },
    "PageContent": {
      "title": "Page Content",
      "description": "Dynamic content for specific site pages.",
      "type": "object",
      "properties": {
        "pageId": { "type": "string", "description": "Unique ID for the page (e.g., 'home', 'about', 'global')." },
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "introTitle": { "type": "string" },
        "introContent": { "type": "string" },
        "heroImageUrlDesktop": { "type": "string" },
        "heroImageUrlMobile": { "type": "string" },
        "siteName": { "type": "string", "description": "Brand name used in Navbar." },
        "siteSubtitle": { "type": "string", "description": "Brand slogan used in Navbar." },
        "updatedAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/blogPosts/{postId}": {
      "schema": { "$ref": "#/entities/BlogPost" },
      "description": "Public Blog Posts. Rules: allow read: if true; allow write: if request.auth != null;"
    },
    "/siteContent/{pageId}": {
      "schema": { "$ref": "#/entities/PageContent" },
      "description": "Dynamic content for site pages. Rules: allow read: if true; allow write: if request.auth != null;"
    }
  }
}
